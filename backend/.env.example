PORT=3001 # HTTP port the API listens on
NODE_ENV=development # Node environment: development|production|test

ANTHROPIC_API_KEY=your_anthropic_api_key # Claude API key from the Anthropic console (server-side only)
ANTHROPIC_MODEL=claude-sonnet-4-5 # Default Claude model id used for chat/completions
AI_PROVIDER=anthropic # Set to 'anthropic' or 'gemini'
GEMINI_API_KEY=your_gemini_api_key # Google AI Studio API key if using Gemini
# IMPORTANT: Use gemini-2.0-flash or higher for reliable tool/function calling.
# gemini-1.5-flash has inconsistent tool support and should NOT be used.
GEMINI_MODEL=gemini-2.0-flash # Default Gemini model

SUPABASE_URL=https://your-project.supabase.co # Supabase project URL (Project Settings -> API)
SUPABASE_ANON_KEY=your_public_anon_key # Public anon key for client apps with RLS enforced
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key # Server-side only secret key with RLS bypass privileges

EXTENSION_ORIGIN=* # Allowed chrome-extension:// origin; set to chrome-extension://<your-extension-id> in prod
MAX_PAGE_CONTENT_CHARS=8000 # Maximum characters allowed for page content payloads
